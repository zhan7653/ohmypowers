#!/usr/bin/env bash
# SessionStart hook for ohmypowers-think plugin

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

using_ohmypowers_content=$(cat "${PLUGIN_ROOT}/skills/using-ohmypowers-think/SKILL.md" 2>&1 || echo "Error reading using-ohmypowers-think skill")

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

using_ohmypowers_escaped=$(escape_for_json "$using_ohmypowers_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have ohmypowers-think.\n\n**Below is the full content of your 'using-ohmypowers-think' skill - your introduction to using skills. For all other skills, use the 'Skill' tool:**\n\n${using_ohmypowers_escaped}\n</EXTREMELY_IMPORTANT>"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
